# ==========================================
# Ecommerce Platform — Environment Variables
# ==========================================

# ─── Database ───
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ecommerce

# ─── Redis ───
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ───
JWT_ACCESS_SECRET=your-access-token-secret-min-32-chars-change-in-production
JWT_REFRESH_SECRET=your-refresh-token-secret-min-32-chars-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Cookie ───
COOKIE_SECURE=false
COOKIE_DOMAIN=

# ─── App ───
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000
STOREFRONT_URL=http://localhost:8000
ADMIN_URL=http://localhost:8001
CORS_ORIGIN=http://localhost:8000

# ─── Stripe (Payment Gateway) ───
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_API_VERSION=2024-12-18.acacia

# ─── Email ───
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@yourplatform.com
SMTP_PASSWORD=your-smtp-password
EMAIL_FROM=noreply@yourplatform.com

# ─── Storage/CDN ───
CDN_URL=https://cdn.yourplatform.com
# For local dev, use local file storage or MinIO

# ─── Queue ───
BULLMQ_PREFIX=ecommerce

# ─── Security ───
BCRYPT_SALT_ROUNDS=12
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=4

# ─── Rate Limiting ───
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# ─── Monitoring ───
OTEL_SERVICE_NAME=ecommerce
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
