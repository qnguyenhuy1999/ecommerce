# ==========================================
# Ecommerce Platform — Environment Variables
# ==========================================

# ─── Database ───
DATABASE_URL=postgresql://postgres:1234@localhost:5432/ecommerce

# ─── Redis ───
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── App URLs ───
NODE_ENV=development
PORT=3000
WORKER_PORT=3100
API_URL=http://localhost:3000
STOREFRONT_URL=http://localhost:8000
ADMIN_URL=http://localhost:8001
CORS_ORIGIN=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=Ecommerce

# ─── JWT ───
JWT_ACCESS_SECRET=your-access-token-secret-min-32-chars-change-in-production
JWT_REFRESH_SECRET=your-refresh-token-secret-min-32-chars-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Cookie ───
COOKIE_SECURE=false
COOKIE_DOMAIN=

# ─── Security ───
BCRYPT_SALT_ROUNDS=12
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=4

# ─── Stripe ───
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_API_VERSION=2024-12-18.acacia

# ─── Email ───
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM=noreply@ecommerce.local
EMAIL_FROM=noreply@ecommerce.local

# ─── Queue ───
BULLMQ_PREFIX=ecommerce
ENABLE_QUEUE_BOARD=true

# ─── Rate Limiting ───
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# ─── Observability ───
LOG_LEVEL=debug
OTEL_SERVICE_NAME=ecommerce
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
