{
  "name": "ecommerce",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "pnpm -w exec prettier --write \"**/*.{ts,tsx,md,stories.tsx}\" --ignore-path .prettierignore \"!apps/api/**\" \"!apps/worker/**\" \"!packages/database/**\"",
    "format:check": "pnpm -w exec prettier --check \"**/*.{ts,tsx,md,stories.tsx}\" --ignore-path .prettierignore \"!apps/api/**\" \"!apps/worker/**\" \"!packages/database/**\"",
    "type-check": "turbo type-check",
    "test": "turbo test",
    "test:e2e": "turbo test:e2e",
    "db:generate": "cd packages/database && npx prisma generate",
    "db:migrate": "cd packages/database && npx prisma migrate dev",
    "db:seed": "cd packages/database && npx prisma db seed",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "clean": "turbo clean && rm -rf node_modules",
    "storybook": "pnpm --filter @ecom/ui storybook",
    "storybook:admin": "pnpm --filter @ecom/ui-admin storybook",
    "storybook:storefront": "pnpm --filter @ecom/ui-storefront storybook",
    "build:ui": "pnpm --filter @ecom/ui build",
    "build:ui:all": "pnpm --filter @ecom/ui --filter @ecom/ui-admin --filter @ecom/ui-storefront build"
  },
  "devDependencies": {
    "@babel/parser": "^7.29.2",
    "@babel/plugin-proposal-decorators": "^7.29.0",
    "@trivago/prettier-plugin-sort-imports": "^5.2.0",
    "@turbo/gen": "^2.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "madge": "^8.0.0",
    "prettier": "^3.2.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.58.2",
    "vite": "^7.1.12"
  },
  "prettier": "./.prettierrc.mjs",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.12.0"
}
