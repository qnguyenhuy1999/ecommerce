# ==========================================
# Ecommerce Worker — Environment Variables
# ==========================================

NODE_ENV=development
WORKER_PORT=3100
DATABASE_URL=postgresql://postgres:1234@localhost:5432/ecommerce
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
BULLMQ_PREFIX=ecommerce
LOG_LEVEL=debug

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM=noreply@ecommerce.local
EMAIL_FROM=noreply@ecommerce.local
