# ==========================================
# Ecommerce Admin API — Environment Variables
# ==========================================

# ─── Application ───
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:8001

# ─── Database ───
DATABASE_URL=postgresql://postgres:1234@localhost:5432/ecommerce

# ─── Redis ───
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ───
JWT_ACCESS_SECRET=your-access-token-secret-min-32-chars-change-in-production
JWT_REFRESH_SECRET=your-refresh-token-secret-min-32-chars-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Cookie ───
COOKIE_SECURE=false
COOKIE_DOMAIN=

# ─── Security ───
BCRYPT_SALT_ROUNDS=12
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=4

# ─── Rate Limiting ───
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
